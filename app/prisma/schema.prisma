generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Player {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  accountStatus       String    @default("PENDING")
  forcePasswordChange Boolean   @default(false)
  passwordHash        String?
  role                String    @default("PLAYER")
  aiPreferences       Json?
  apiKeys             Json?
  mfaEnabled          Boolean   @default(false)
  mfaSecret           String?
  usageStats          Json?
  apiEnabled          Json?
  customThemes        Json?
  journeys            Journey[]
}

model Journey {
  id              String   @id @default(cuid())
  playerId        String
  genre           String
  status          String   @default("active")
  history         Json
  flags           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  memories        Json?
  settings        Json?
  lastPdfUrl      String?
  lastPdfHash     String?
  lastTextPdfUrl  String?
  lastTextPdfHash String?
  playerStatus    Json?
  playerInventory Json?
  finalStatus     Json?
  finalInventory   Json?
  finalSkills     Json?
  finalStatusHistory Json?
  finalNotifications Json?
  assets          Asset[]
  player          Player   @relation(fields: [playerId], references: [id])
  scenes          Scene[]
}

model Scene {
  id                String   @id @default(cuid())
  journeyId         String
  sceneId           String
  order             Int
  narration         String
  visualDescription String
  audioDescription  String?
  imageUrl          String?
  audioUrl          String?
  options           Json?
  tacticalOptions   Json?
  puzzle            Json?
  selectedOption    String?
  statusChanges     Json?
  inventoryChanges  Json?
  skillChanges      Json?
  worldUpdate       Json?
  isGameOver        Boolean  @default(false)
  createdAt         DateTime @default(now())
  journey           Journey  @relation(fields: [journeyId], references: [id], onDelete: Cascade)

  @@index([journeyId])
  @@index([order])
}

model Asset {
  id        String   @id @default(cuid())
  journeyId String
  url       String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
  journey   Journey  @relation(fields: [journeyId], references: [id])
}

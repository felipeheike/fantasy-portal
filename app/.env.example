# App Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://fp_user:fp_password@db_postgres:5432/fantasy_portal_db?schema=public"

# Redis
REDIS_URL="redis://cache_redis:6379"

# AI Provider Configuration
ACTIVE_TEXT_PROVIDER="google" # 'google', 'openai', 'anthropic'
ACTIVE_IMAGE_PROVIDER="google" # 'google', 'openai'

# Global Model Configuration
TEXT_MODEL="gemini-2.5-flash"
IMAGE_MODEL="imagen-3.0-generate-001" # Tentando versão base do v3 ou v2

# IA Keys (To be filled)
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=

# Interaction Variety
MAX_REPETITIVE_INTERACTIONS=2

# MinIO / S3 Configuration
MINIO_ENDPOINT="localhost"
MINIO_PORT="25037"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="fantasy-portal-assets"
MINIO_USE_SSL="false"
NEXT_PUBLIC_ASSETS_URL="http://localhost:25037/fantasy-portal-assets"

# Spotify API Integration (For dynamic soundtracks)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Optional: Override Spotify redirect URI (e.g., http://127.0.0.1:25039/api/audio/spotify/callback or https://fantasyportal.duplecake.space/api/audio/spotify/callback)
SPOTIFY_REDIRECT_URI=

